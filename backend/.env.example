# ── Database ──
# Railway provides DATABASE_URL automatically when you add a Postgres plugin
# Format: postgresql://user:pass@host:port/dbname
# The app auto-converts to asyncpg driver for SQLAlchemy
DATABASE_URL=postgresql://buckflow:buckflow@localhost:5432/buckflow
# Optional: explicit sync URL for Alembic (auto-derived if omitted)
SYNC_DATABASE_URL=

# ── Auth ──
SECRET_KEY=change-me-to-a-real-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── WhatsApp Cloud API ──
WHATSAPP_VERIFY_TOKEN=your-verify-token-here
WHATSAPP_API_TOKEN=your-meta-api-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_URL=https://graph.facebook.com/v21.0

# ── OpenAI ──
OPENAI_API_KEY=your-openai-key-here

# ── Redis (optional, for Celery background tasks) ──
REDIS_URL=redis://localhost:6379/0

# ── Paystack ──
PAYSTACK_SECRET_KEY=your-paystack-secret
PAYSTACK_PUBLIC_KEY=your-paystack-public

# ── Environment ──
ENVIRONMENT=development
DEBUG=true
